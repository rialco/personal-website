---
const cards = [
  {
    project: 'Crescent Garden',
    imagePath: '/images/crescent.jpg',
    technologies: ['Javascript', 'PHP', 'Woocommerce', 'SAP B1', 'MySQL'],
    keypoints: [
      'Desarrollador fullstack',
      'Experiencia manejando un ecommerce con miles de visitantes diarios.',
      'Refactorización de funcionalidades personalizadas.',
      'Encargado del desarrollo y manejo de nuevos proyectos web.',
      'Encargado de mantener y optimizar la integración con SAP mediante el Service Layer API.',
    ],
  },
  {
    project: 'Li.Fi',
    imagePath: '/images/lifi_jumper.jpg',
    technologies: ['NodeJs', 'Typescript', 'MongoDB', 'Express', 'Fastify', 'Redis'],
    keypoints: [
      'Desarrollador backend',
      'Validación de "payload" en los endpoints.',
      'Experiencia implementando sistema de estimacion de gas en blockchain.',
      'Experiencia "mocking" la suite de tests para simular los llamados a la red.',
      'Migración de Redis hacia MongoDB para optimizar procesos y uso de memoria.',
      'Refactorización de "middlewares" de autenticación.',
      'Implementación de nuevo microservicio para auto servicio de backoffice.',
    ],
  },
  {
    project: 'Modo',
    imagePath: '/images/modo.jpg',
    technologies: ['NodeJS', 'NestJs', 'Express', 'DynamoDB', 'PostgreSQL', 'JWT', 'Docker', 'Kubernetes'],
    keypoints: [
      'Desarrollador backend',
      'Startup fintech bajo la metologia SCRUM.',
      'Encargado de agregar funciones a los diversos micro-servicios y mantenimiento de funciones legacy.',
      'Colaboración en la migración de monolito a micro-servicios.',
      'Implementacion de estrategias de autenticación con JWT.',
      'Experiencia con suites de testing con Jest',
      'Asistencia en revisiones de codigo.',
    ],
  },
  {
    project: 'Globant',
    imagePath: '/images/globant.jpg',
    technologies: [
      'NodeJs',
      'Javascript',
      'Typescript',
      'Express',
      'Microsoft SQL Server',
      'Jenkins',
      'Docker',
      'Kubernetes',
    ],
    keypoints: [
      'Desarrollador Fullstack',
      'Consultor en compañias de Estados Unidos y Latinoamerica.',
      'Adaptación a diversos equipos multidisciplinarios de manera fluida y en modalid de "Staff augmentation".',
      'Scrum Master',
    ],
  },
];
---

<section class="experience reveal" id="experience">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">01</span>
      <h2>Experiencia</h2>
    </div>

    <div class="list-wrapper">
      {cards.map((card, index) => (
        <div class="list-item border-bot reveal">
          <div class="item-grid">
            <div class="item-visual">
              <div class="image-mask">
                <img src={card.imagePath} alt={card.project} loading="lazy" />
              </div>
            </div>
            <div class="item-content">
              <h3>{card.project}</h3>
              <ul class="tech-list">
                {card.technologies.map((tech) => (
                  <li>{tech}</li>
                ))}
              </ul>
              <div class="details">
                {card.keypoints.map((point) => (
                  <p>{point}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 15vh 0;
    position: relative;
    z-index: 2;
    background-color: var(--color-white);
  }

  .container {
    padding: 0 4vw;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 8rem;
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-indigo);
  }

  .section-header h2 {
    color: var(--color-navy);
  }

  .list-wrapper {
    display: flex;
    flex-direction: column;
  }

  .list-item {
    padding: 4rem 0;
    position: relative;
    transition: background-color 0.5s var(--fluid-bezier);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .list-item:hover {
    background-color: rgba(0,0,0,0.02);
  }

  .item-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .item-grid {
      grid-template-columns: 4fr 6fr;
      gap: 4rem;
    }
  }

  .item-visual {
    width: 100%;
  }

  .image-mask {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-charcoal);
  }

  .image-mask img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(80%);
    transition: all 0.7s var(--fluid-bezier);
    transform: scale(1.05);
  }

  .list-item:hover .image-mask img {
    filter: grayscale(0%);
    transform: scale(1.1);
  }

  .item-content h3 {
    margin-bottom: 1.5rem;
    color: var(--color-navy);
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    list-style: none;
    margin-bottom: 2rem;
  }

  .tech-list li {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--color-blue);
    border: 1px solid rgba(96, 165, 250, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .details {
    color: var(--color-charcoal);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  .details p {
    margin-bottom: 0.5rem;
  }

  .details p::before {
    content: "—";
    margin-right: 0.5rem;
    color: var(--color-indigo);
  }

</style>
