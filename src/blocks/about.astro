---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

import Link from '../components/Link.astro';
import profileImg from '../images/hero-image.png';
---

<section class="hero reveal" id="about">
  <div class="container layout-grid">
    <div class="col-main">
      <h2 class="role">Fullstack Developer<br>& Software Architect</h2>
      <h1 class="name">RICARDO<br>CORREA</h1>
      <p class="bio">
        With over 8 years of experience, I build high-end scalable applications, bridging the gap between design and deep technical implementations.
      </p>

      <div class="tech-marquee-wrapper border-bot">
        <ul class="tech-stack">
          <li>NodeJs <Icon name="devicon:nodejs" /></li>
          <li>MongoDB <Icon name="devicon:mongodb" /></li>
          <li>PostgreSQL <Icon name="devicon:postgresql" /></li>
          <li>React <Icon name="devicon:react" /></li>
          <li>SolidJs <Icon name="devicon:solidjs" /></li>
          <li>Astro <Icon name="devicon:astro" /></li>
          <li>Rust <Icon name="devicon:rust" /></li>
          <li>NestJs <Icon name="devicon:nestjs" /></li>
        </ul>
      </div>

      <div class="social-links">
        <Link text="LinkedIn" className="about-link" icon="linkedin" href="https://www.linkedin.com/in/ralvarezcorrea/" target="_blank" />
        <Link text="Github" className="about-link" icon="github" href="https://github.com/rialco" target="_blank" />
      </div>
    </div>
    <div class="col-img">
      <div class="image-wrapper">
        <Image src={profileImg} alt="Profile image" width="600" height="800" class="profile-pic" loading="eager" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding-top: 15vh;
    padding-bottom: 10vh;
    display: flex;
    align-items: center;
  }

  .container {
    padding: 0 4vw;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 1024px) {
    .layout-grid {
      grid-template-columns: 6fr 4fr;
      align-items: center;
    }
  }

  .role {
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: var(--color-taupe);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .name {
    margin-bottom: 2rem;
    line-height: 0.85;
    margin-left: -0.05em; /* Optical alignment due to Anton tracking */
  }

  .bio {
    max-width: 500px;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--color-indigo-light);
    margin-bottom: 4rem;
    line-height: 1.6;
  }

  .tech-marquee-wrapper {
    margin-bottom: 4rem;
    padding-bottom: 2rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    list-style: none;
  }

  .tech-stack li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-beige);
  }

  .tech-stack li [data-icon] {
    font-size: 1.2rem;
    opacity: 0.8;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .col-img {
    position: relative;
    width: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--color-charcoal);
  }

  .profile-pic {
    width: 100%;
    height: 100%;
    object-fit: cover;

    transition: transform 0.5s var(--fluid-bezier);
  }

  .image-wrapper:hover .profile-pic {
    transform: scale(1.1);
  }
</style>
