---
const currentYear = new Date().getFullYear();
---

<footer class="footer reveal">
  <div class="container border-bot">
    <div class="footer-content">
      <h3 class="brand">Ricardo Correa</h3>
      <div class="footer-links">
        <a href="https://github.com/rialco" target="_blank">Github</a>
        <a href="https://www.linkedin.com/in/ralvarezcorrea/" target="_blank">LinkedIn</a>
        <a href="https://www.youtube.com/@rialdev" target="_blank">YouTube</a>
      </div>
    </div>
  </div>
  <div class="container copy-container">
    <p class="copyright">&copy; {currentYear} Ricardo Correa. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding-top: 10vh;
    padding-bottom: 5vh;
    background-color: var(--color-navy);
  }

  .container {
    padding: 0 4vw;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  .border-bot {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 4rem;
    margin-bottom: 2rem;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  .brand {
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--color-beige);
    line-height: 0.8;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.9rem;
    color: var(--color-taupe);
  }

  .copy-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-indigo-light);
    opacity: 0.5;
  }
</style>
