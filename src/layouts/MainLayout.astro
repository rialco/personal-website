---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  theme?: 'dark' | 'light';
}

const { title, theme = 'dark' } = Astro.props;
---

<!doctype html>
<html lang='es-CO' class={`theme-${theme}`}>
  <head>
    <meta charset='UTF-8' />
    <meta
      name='description'
      content='Descubre los diversos proyectos en los que he trabajado a lo largo de mi carrera como desarrollador Fullstack. NodeJs, Typescript, MongoDB, PostgreSQL y Rust son algunas de las herramientas y tecnologías que he utilizado.'
    />
    <meta name='viewport' content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no' />
    <link rel='icon' type='image/svg+xml' href='/favicon.png' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Ambient blurs wrapper to prevent overflow -->
    <div class="ambient-wrapper">
      <div class="ambient-blur blur-1"></div>
      <div class="ambient-blur blur-2"></div>
      <div class="ambient-blur blur-3"></div>
    </div>

    <Navbar />
    <slot />
    <Footer />

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
      });

      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-navy: #0a0f24;       /* Deep Midnight Blue background */
    --color-indigo: #4f46e5;     /* Tailwind Indigo 600 */
    --color-indigo-light: #e0e7ff; /* Tailwind Indigo 100 */
    --color-white: #ffffff;
    --color-taupe: #818cf8;      /* Replaced taupe with Indigo 400 */
    --color-beige: #93c5fd;      /* Replaced beige with Blue 300 */
    --color-blue: #2563eb;       /* Tailwind Blue 600 */
    --color-soft-blue: #dbeafe;  /* Tailwind Blue 100 */
    --color-charcoal: #1e1b4b;   /* Replaced charcoal with Indigo 950 */

    --font-heading: 'Anton', sans-serif;
    --font-body: 'Plus Jakarta Sans', sans-serif;

    --fluid-bezier: cubic-bezier(0.16, 1, 0.3, 1);
  }

  html.theme-light {
    --color-navy: #ffffff; /* Replaces dark background with white */
    --color-indigo-light: #333333; /* Replaces light text with dark gray body text */
    --color-white: #111111; /* Replaces white headings with nearly black headings */
    --color-taupe: #666666; /* Subtitle color */
    --color-blue: #2563eb;
  }

  * {
    box-sizing: border-box;
    padding: 0;
    margin: 0;
    cursor: crosshair;
  }

  html {
    scroll-behavior: smooth;
    background-color: var(--color-navy);
    color: var(--color-indigo-light);
  }

  body {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.6;
    position: relative;
    min-height: 100vh;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    text-transform: uppercase;
    font-weight: 400; /* Anton only has weight 400 */
    letter-spacing: -0.02em; /* tracking-tighter */
    line-height: 1;
    color: var(--color-white);
  }

  /* Typography Scale */
  h1 { font-size: clamp(4rem, 12vw, 15rem); }
  h2 { font-size: clamp(3rem, 8vw, 10rem); }
  h3 { font-size: clamp(2rem, 5vw, 6rem); }
  h4 { font-size: clamp(1.5rem, 3vw, 4rem); letter-spacing: 0; }
  
  /* Blog / Light Theme Typography Adjustments */
  html.theme-light h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: 0; line-height: 1.2; margin-bottom: 1rem; text-transform: none; font-weight: 600; }
  html.theme-light h2 { font-size: clamp(1.5rem, 4vw, 2rem); letter-spacing: 0; line-height: 1.3; text-transform: none; font-weight: 600; }
  html.theme-light h3 { font-size: clamp(1.2rem, 3vw, 1.5rem); letter-spacing: 0; line-height: 1.4; text-transform: none; font-weight: 600; }
  html.theme-light h4 { font-size: clamp(1.1rem, 2vw, 1.25rem); text-transform: none; font-weight: 600; }
  
  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.5s var(--fluid-bezier);
  }

  a:hover {
    opacity: 0.7;
  }

  /* Utility classes */
  .border-bot {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Ambient Blur shapes */
  .ambient-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  .ambient-blur {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .blur-1 {
    width: 40vw;
    height: 40vw;
    background: var(--color-blue);
    top: -10vw;
    left: -10vw;
    opacity: 0.15;
  }

  .blur-2 {
    width: 30vw;
    height: 30vw;
    background: var(--color-indigo);
    bottom: 20vh;
    right: -5vw;
    opacity: 0.1;
  }

  .blur-3 {
    width: 50vw;
    height: 30vw;
    background: var(--color-taupe);
    top: 50vh;
    left: 20vw;
    opacity: 0.08;
  }

  /* Scroll Reveal Defaults */
  .reveal {
    opacity: 0;
    transform: translateY(10px);
    transition: all 1s var(--fluid-bezier);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
